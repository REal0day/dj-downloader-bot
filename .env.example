# ---- Discord ----
# Bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# Optional: restrict the bot to a single Discord user ID (your own).
# Leave blank to allow anyone in the server. Strongly recommended to set this.
ALLOWED_USER_ID=

# Optional: restrict to a single channel ID. Leave blank to allow any channel.
ALLOWED_CHANNEL_ID=

# Command prefix
PREFIX=!dl

# ---- Output ----
# Where downloaded MP3s land. This should be the Rekordbox WATCH FOLDER.
# Since the bot runs in WSL but Rekordbox runs on Windows, point this at a
# Windows path via the /mnt/c mount. Example:
#   /mnt/c/Users/Chris/Music/DJ-Downloads
OUTPUT_DIR=/mnt/c/Users/YOUR_USERNAME/Music/DJ-Downloads

# Comma-separated genre subfolders shown as buttons after you pick a track.
# The bot creates these inside OUTPUT_DIR as needed. Max 24 here (Discord limit).
GENRES=Hard Techno,Schranz,Industrial Techno,Tech House,Melodic Techno,Uncategorized

# ---- Search ----
# How many YouTube results to show per search (1-5)
SEARCH_RESULTS=5

# ---- Download ----
# Audio bitrate for the MP3 (DJ standard is 320K)
AUDIO_BITRATE=320K

# Path to yt-dlp binary (just "yt-dlp" if it's on PATH)
YTDLP_PATH=yt-dlp

# ---- Spotify (for !dlplaylist) ----
# Free app credentials from developer.spotify.com — Web API, Client Credentials only.
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# ---- Verification ----
# AcoustID API key — register free at https://acoustid.org/api-key
# Used to fingerprint downloads and confirm artist, title, release year, and BPM.
ACOUSTID_API_KEY=your_acoustid_key_here

# ---- Artist watcher ----
# Channel ID where new-release alerts are posted (!dlwatch).
# Enable Developer Mode in Discord (Settings → Advanced), right-click the
# channel name → Copy Channel ID.
WATCH_CHANNEL_ID=

# ---- New releases (!dlnew) ----
# Beatport genre page to scrape for new tracks.
# Navigate to your genre on beatport.com, copy the URL from the Tracks tab.
# Default: Hard Techno
BEATPORT_NEW_URL=https://www.beatport.com/genre/hard-techno/2/tracks
# Charts page for !dlchart (auto-finds the latest monthly chart)
BEATPORT_CHARTS_URL=https://www.beatport.com/genre/hard-techno/2/charts
# Optional: path to a Netscape-format cookies.txt exported from your browser.
# Required for Beatport chart/new-releases pages (they need a login).
# Export with the "Get cookies.txt LOCALLY" Chrome extension.
BEATPORT_COOKIES_FILE=
